generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum RecipeStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum AudioLanguage {
  ENGLISH
  HINDI
  MARATHI
}

enum CommunityPostStatus {
  PENDING
  PUBLISHED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  recipes              Recipe[]           @relation("RecipeAuthor")
  submissions          RecipeSubmission[]
  moderatedSubmissions RecipeSubmission[] @relation("SubmissionModerator")
  favorites            Favorite[]
  ratings              Rating[]
  comments             Comment[]
  communityPosts       CommunityPost[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model State {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  imageUrl    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  recipes     Recipe[]
}

model Category {
  id        String           @id @default(cuid())
  name      String           @unique
  slug      String           @unique
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  recipes   RecipeCategory[]
}

model Festival {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  imageUrl    String?
  month       Int?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  recipes     Recipe[]
}

model Recipe {
  id                String         @id @default(cuid())
  title             String
  slug              String         @unique
  description       String?        @db.Text
  story             String?        @db.Text
  ingredients       Json           @default("[]")
  instructions      Json           @default("[]")
  prepTime          Int?
  cookTime          Int?
  servings          Int?
  difficulty        Difficulty     @default(MEDIUM)
  status            RecipeStatus   @default(PUBLISHED)
  featured          Boolean        @default(false)
  trending          Boolean        @default(false)
  communityFavorite Boolean        @default(false)
  grandmasPick      Boolean        @default(false)
  imageUrl          String?
  imagePublicId     String?
  seoTitle          String?
  seoDescription    String?        @db.Text
  viewCount         Int            @default(0)
  publishedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  stateId      String?
  state        State?    @relation(fields: [stateId], references: [id])
  festivalId   String?
  festival     Festival? @relation(fields: [festivalId], references: [id])
  authorId     String
  author       User      @relation("RecipeAuthor", fields: [authorId], references: [id])
  submissionId String?   @unique
  submission   RecipeSubmission? @relation(fields: [submissionId], references: [id])

  categories  RecipeCategory[]
  audioTracks RecipeAudio[]
  favorites   Favorite[]
  ratings     Rating[]
  comments    Comment[]
  communityPosts CommunityPost[]
}

model RecipeCategory {
  recipeId   String
  categoryId String
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([recipeId, categoryId])
}

model RecipeSubmission {
  id            String       @id @default(cuid())
  rawContent    String       @db.Text
  title         String?
  story         String?      @db.Text
  imageUrl      String?
  imagePublicId String?
  status        RecipeStatus @default(PENDING)
  adminNotes    String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  userId        String
  user          User   @relation(fields: [userId], references: [id])
  moderatorId   String?
  moderator     User?  @relation("SubmissionModerator", fields: [moderatorId], references: [id])
  publishedRecipe Recipe?
}

model RecipeAudio {
  id        String        @id @default(cuid())
  recipeId  String
  recipe    Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  language  AudioLanguage
  audioUrl  String
  publicId  String?
  duration  Int?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([recipeId, language])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, recipeId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  value     Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, recipeId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  isHidden  Boolean  @default(false)
  userId    String
  recipeId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunityPost {
  id            String              @id @default(cuid())
  title         String?
  content       String              @db.Text
  imageUrl      String?
  imagePublicId String?
  status        CommunityPostStatus @default(PENDING)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeId String?
  recipe   Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)
}
